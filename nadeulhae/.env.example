NEXT_PUBLIC_API_URL=/api/weather
NEXT_PUBLIC_MOCK_MODE=false
KMA_API_KEY=your_kma_api_key
AIRKOREA_API_KEY=your_airkorea_api_key
AIRKOREA_DAILY_LIMIT=500
APIHUB_KEY=your_apihub_key
KMA_NX=63
KMA_NY=89
AIRKOREA_STATION_NAME=송천동
JEONJU_AREA_CODE=11B20201
MID_TERM_LAND_AREA_CODE=11F10000
MID_TERM_TEMP_AREA_CODE=11F10201
TM_X=180750
TM_Y=358250
JEONJU_STN_ID=146
NIER_STATION_NAME=전북권
DB_HOST=your_tidb_host
DB_PORT=4000
DB_USER=your_tidb_user
DB_PASSWORD=your_tidb_password
DB_NAME=nadeulhae
DB_CA_PATH=/etc/ssl/certs/ca-certificates.crt
DB_POOL_LIMIT=10
ALWAYS_SECURE_COOKIES=true
FACTCHAT_API_KEY=your_factchat_api_key
FACTCHAT_BASE_URL=https://factchat-cloud.mindlogic.ai/v1/gateway
FACTCHAT_MODEL=SAIT 3 Pro
FACTCHAT_FALLBACK_MODEL=solar-pro3
TRUST_PROXY_HEADERS=true
# ===== 보안 키 (반드시 별도의 강력한 랜덤값 사용, 두 키는 서로 달라야 함) =====
AUTH_PEPPER=replace_with_a_long_random_secret
DATA_PROTECTION_KEY=replace_with_another_long_random_secret
AUTH_SESSION_DAYS=30
AUTH_SESSION_REFRESH_WINDOW_HOURS=72
AUTH_COOKIE_NAME=nadeulhae_auth
AUTH_MAX_SESSIONS_PER_USER=5
APP_BASE_URL=https://your-domain.example
